USE online_retail;

-- Initial Data Check

SELECT *
FROM online_retail;

-- Revenue Calculation

SELECT InvoiceNo, CustomerID, Quantity, UnitPrice, ROUND(Quantity * UnitPrice, 2) AS revenue
FROM online_retail
WHERE Quantity > 0;

-- Total Revenue Calculation For December 

SELECT ROUND(SUM(Quantity * UnitPrice), 2) AS total_revenue
FROM online_retail
WHERE Quantity > 0;

-- Daily Revenue For December

SELECT 
	DATE_FORMAT(InvoiceDate, '%Y-%m-%d') AS date,
    ROUND(SUM(Quantity * UnitPrice), 2) AS daily_revenue
FROM online_retail
WHERE Quantity > 0
GROUP BY date
ORDER BY date;

-- Highest Daily Revenue For December 

SELECT 
	DATE_FORMAT(InvoiceDate, '%Y-%m-%d') AS date,
    ROUND(SUM(Quantity * UnitPrice), 2) AS daily_revenue
FROM online_retail
WHERE Quantity > 0
GROUP BY date
ORDER BY daily_revenue DESC
LIMIT 5;

-- Lowest Daily Revenue For December 

SELECT 
	DATE_FORMAT(InvoiceDate, '%Y-%m-%d') AS date,
    ROUND(SUM(Quantity * UnitPrice), 2) AS daily_revenue
FROM online_retail
WHERE Quantity > 0
GROUP BY date
ORDER BY daily_revenue
LIMIT 5;

-- Count Total Orders For Daily

SELECT 
	DATE_FORMAT(InvoiceDate, '%Y-%m-%d') AS date,
    COUNT(Quantity) AS total_orders
FROM online_retail
GROUP BY date;

-- Average Revenue Per Order

SELECT
	ROUND(AVG(order_revenue), 2) AS avg_revenue_per_order
FROM (
	SELECT
		InvoiceNo,
        SUM(Quantity * UnitPrice) AS order_revenue
		FROM online_retail
		WHERE Quantity > 0
		GROUP BY InvoiceNo
) AS order_totals;

-- Top Products BY REVENUE

SELECT StockCode, Description, ROUND(SUM(Quantity * UnitPrice), 2) AS total_revenue
FROM online_retail
WHERE Quantity > 0
GROUP BY StockCode, Description
ORDER BY total_revenue DESC
LIMIT 10;

-- Top Customers By Spending

SELECT CustomerID, ROUND(SUM(Quantity * UnitPrice), 2) AS total_spent
FROM online_retail
WHERE Quantity > 0
GROUP BY CustomerID
ORDER BY total_spent DESC
LIMIT 10;
